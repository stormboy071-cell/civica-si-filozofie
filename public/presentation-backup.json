  "Psihologie": [
    {
      "id": "sec-antichitate",
      "items": [
        {
          "id": "id-mpx3n0o0-bqqxlszap",
          "nume": "Tonul afectiv al proceselor cognitive",
          "type": "standard",
          "image_url": "https://tzedivnhtkojsbqrfpjn.supabase.co/storage/v1/object/public/media/images/id-mpx3n0o0-bqqxlszap-1781171054212.png",
          "isLocalImage": false,
          "detailed_text": "•\tTonul afectiv al proceselor cognitive: Însoțește actele de cunoaștere cu plăcerea/neplăcerea resimțită la perceperea unui obiect sau a unei senzații. \nDe exemplu un miros parfumat sau o melodie, determină la nivel cognitiv o asociere cu ceva plăcut/neplăcut, conducând la anumite senzații. \n",
          "lucrare_relevanta": "",
          "comentariu_filosofic": "Însoțește actele de cunoaștere cu plăcerea/neplăcerea resimțită la perceperea unui obiect sau a unei senzații. "
        },
        {
          "id": "id-mpx3n13w-smcmjd5qt",
          "nume": "Trăirile afective de natură organică",
          "type": "standard",
          "image_url": "https://tzedivnhtkojsbqrfpjn.supabase.co/storage/v1/object/public/media/images/id-mpx3n13w-smcmjd5qt-1781171054205.jpeg",
          "isLocalImage": false,
          "detailed_text": "•\tTrăirile afective de natură organică: Generate de funcționarea organelor interne. De exemplu în cazul bolilor de inimă, specifică este o stare de alarmă interioară.",
          "lucrare_relevanta": "",
          "comentariu_filosofic": "Generate de funcționarea organelor interne."
        },
        {
          "id": "id-mpx3n1m4-bveb40422",
          "nume": "Afectele",
          "type": "standard",
          "image_url": "https://tzedivnhtkojsbqrfpjn.supabase.co/storage/v1/object/public/media/images/id-mpx3n1m4-bveb40422-1781171054207.webp",
          "isLocalImage": false,
          "detailed_text": "•\tAfectele: sunt reacții intense, violente și de scurtă durată. De exemplu: groaza, panica, frica bruscă, accesele de plâns.",
          "lucrare_relevanta": "",
          "comentariu_filosofic": "Sunt reacții intense, violente și de scurtă durată."
        }
      ],
      "title": "1.\tProcese afective primare",
      "contentType": "standard",
      "description": "Sunt elementare și spontane;",
      "_originalIndex": 0
    },
    {
      "id": "sec-renastere",
      "items": [
        {
          "id": "r1",
          "nume": "Emoțiile curente",
          "type": "standard",
          "image_url": "https://tzedivnhtkojsbqrfpjn.supabase.co/storage/v1/object/public/media/images/1781171740699-ti6td8jfmn8-id-ml9qbkng-echtkoh24-1780904202437.webp",
          "isLocalImage": false,
          "detailed_text": "•\tEmoțiile curente: sunt trăiri de scurtă durată, intense, cu desfășurare calmă sau tumultoasă, legate de evenimente specifice.\nExemple: bucurie, tristețe, surpriză, furie\n\n",
          "lucrare_relevanta": "",
          "comentariu_filosofic": "Sunt trăiri de scurtă durată, intense, cu desfășurare calmă sau tumultoasă, legate de evenimente specifice."
        },
        {
          "id": "id-ml9qbkng-echtkoh24",
          "nume": "Emoții superioare ",
          "type": "standard",
          "image_url": "https://tzedivnhtkojsbqrfpjn.supabase.co/storage/v1/object/public/media/images/id-ml9qbkng-echtkoh24-1781171054208.jpeg",
          "isLocalImage": false,
          "detailed_text": "•\tEmoții superioare (intelectuale, estetice, morale): sunt stabile și conștientizate, sunt legate de activitățile desfășurate.\nExemple:  curiozitatea, mirarea, bucuria creației, teama de a nu finaliza un proiect, onoarea, patriotismul.\n",
          "lucrare_relevanta": "",
          "comentariu_filosofic": "Sunt stabile și conștientizate, sunt legate de activitățile desfășurate."
        },
        {
          "id": "id-ml9qbky9-uxg5ddrql",
          "nume": "Dispoziții afective ",
          "type": "standard",
          "image_url": "https://tzedivnhtkojsbqrfpjn.supabase.co/storage/v1/object/public/media/images/id-ml9qbky9-uxg5ddrql-1781171713881.jpeg",
          "isLocalImage": false,
          "detailed_text": "•\tDispoziții afective (stări): Trăiri difuze, cu intensitate redusă și durată lungă, care domină întreaga activitate psihică.\nExemple: stare de optimism general, sau o dispoziție melancolică, fără cauză precisă.\n\n",
          "lucrare_relevanta": "",
          "comentariu_filosofic": "Trăiri difuze, cu intensitate redusă și durată lungă, care domină întreaga activitate psihică."
        }
      ],
      "title": "2. Procese afective complexe",
      "contentType": "standard",
      "description": "Sunt conștiente, de durată medie.",
      "_originalIndex": 1
    },
    {
      "id": "id-ml9pujfa-crx9byfib",
      "items": [
        {
          "id": "id-ml9q461y-unze3nxdd",
          "nume": "Sentimentele",
          "type": "standard",
          "image_url": "https://tzedivnhtkojsbqrfpjn.supabase.co/storage/v1/object/public/media/images/1781171692581-md0rohgod9b-id-ml9q461y-unze3nxdd-1780904202438.png",
          "isLocalImage": false,
          "detailed_text": "•\tSentimentele: Stări afective de lungă durată, complexe, stabile, profund integrate în personalitate;\nExemple:  Iubirea, prietenia, ura.\n",
          "lucrare_relevanta": "",
          "comentariu_filosofic": "Stări afective de lungă durată, complexe, stabile, profund integrate în personalitate;"
        },
        {
          "id": "id-ml9q46fv-euemcw7sk",
          "nume": "Pasiunile",
          "type": "standard",
          "image_url": "https://tzedivnhtkojsbqrfpjn.supabase.co/storage/v1/object/public/media/images/id-ml9q46fv-euemcw7sk-1781171696960.png",
          "isLocalImage": false,
          "detailed_text": "•\tPasiunile: Sentimente cu intensitate foarte mare, orientate constant către un obiect/domeniu, care domină întreaga activitate a persoanei. \nExemple: pasiunea pentru muzică, sau sport, colecțiile, hobbyurile.\n\n",
          "lucrare_relevanta": "",
          "comentariu_filosofic": "Sentimente cu intensitate foarte mare, orientate constant către un obiect/domeniu, care domină întreaga activitate a persoanei. "
        }
      ],
      "title": "3.Procese afective superioare",
      "contentType": "standard",
      "description": "",
      "_originalIndex": 2
    }
